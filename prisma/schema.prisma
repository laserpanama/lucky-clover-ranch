// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Using SQLite for the preview to work immediately.
  // To use PostgreSQL, change the provider to "postgresql" and update the URL in .env.
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Animal {
  id          Int            @id @default(autoincrement())
  tagNumber   String         @unique
  name        String
  breed       String
  status      String         // e.g., "healthy", "injured", "rented"
  category    String         @default("rodeo")
  dateOfBirth DateTime
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  rentals     Rental[]
  healthRecords HealthRecord[]
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  email        String   @unique
  organization String?
  notes        String?
  createdAt    DateTime @default(now())
  rentals      Rental[]
}

model Rental {
  id          Int      @id @default(autoincrement())
  animalId    Int
  clientId    Int
  startDate   DateTime
  endDate     DateTime
  status      String   // e.g., "active", "completed", "cancelled"
  price       Float
  contractUrl String?
  notes       String?
  createdAt   DateTime @default(now())
  animal      Animal   @relation(fields: [animalId], references: [id])
  client      Client   @relation(fields: [clientId], references: [id])
}

model HealthRecord {
  id          Int      @id @default(autoincrement())
  animalId    Int
  type        String   // e.g., "vaccination", "checkup"
  description String
  date        DateTime
  nextDueDate DateTime?
  animal      Animal   @relation(fields: [animalId], references: [id])
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  role  String // e.g., "admin", "manager"
}